{
	"name": "@sppg2001/atomize",
	"version": "1.2.4",
	"description": "Automatically generate tasks from user stories with smart templates",
	"type": "module",
	"main": "./dist/cli/index.js",
	"bin": {
		"atomize": "dist/cli/index.js",
		"atom": "dist/cli/index.js"
	},
	"publishConfig": {
		"access": "public",
		"tag": "latest"
	},
	"files": [
		"dist",
		"templates/templates",
		"templates/mixins",
		"README.md",
		"LICENSE",
		".env.example",
		"examples"
	],
	"scripts": {
		"dev": "ATOMIZE_DEV=true bun run src/cli/index.ts",
		"build": "bun run typecheck && bun run build:bun",
		"postbuild": "node make-executable.js",
		"build:bun": "node ./scripts/prepare-dist.mjs && bun build ./src/cli/index.ts --outdir ./dist/cli --target node --format esm --external keytar",
		"build:standalone": "bun build src/cli/index.ts --compile --outfile atomize",
		"prepublishOnly": "npm run build",
		"test": "bun test",
		"test:unit": "bun test tests/unit",
		"test:integration": "bun test tests/integration",
		"test:watch": "bun test --watch",
		"test:coverage": "bun test --coverage --coverage-reporter=lcov",
		"typecheck": "tsc --noEmit",
		"audit": "bun audit --audit-level=moderate",
		"validate": "bun run src/cli/index.ts validate",
		"validate:package": "node ./scripts/validate-package.mjs",
		"check": "bun typecheck && bun test",
		"lint": "bunx biome check --max-diagnostics 100",
		"lint:fix": "bunx biome check --fix --max-diagnostics 100",
		"benchmark": "bun run benchmarks/index.ts"
	},
	"keywords": [
		"devops",
		"azure-devops",
		"task-automation",
		"task-generation",
		"agile",
		"scrum",
		"sprint-planning",
		"cli",
		"automation",
		"productivity"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Simao-Pereira-Gomes/atomize.git"
	},
	"bugs": {
		"url": "https://github.com/Simao-Pereira-Gomes/atomize/issues"
	},
	"author": "Simão Pereira Gomes",
	"license": "MIT",
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@types/bun": "1.3.13",
		"@types/keytar": "^4.4.2",
		"@types/node": "^25.6.0",
		"@types/semver": "^7.7.1",
		"bun-types": "^1.3.13",
		"mitata": "^1.0.34",
		"typescript": "^6.0.3"
	},
	"peerDependencies": {
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"@clack/prompts": "^1.2.0",
		"azure-devops-node-api": "^15.1.2",
		"chalk": "^5.6.2",
		"commander": "^14.0.3",
		"keytar": "^7.9.0",
		"openai": "^6.34.0",
		"semver": "^7.7.4",
		"ts-pattern": "^5.9.0",
		"yaml": "^2.8.3",
		"zod": "^4.3.6"
	},
	"overrides": {
		"qs": "6.15.1",
		"underscore": "1.13.8"
	},
	"engines": {
		"node": ">=18.0.0"
	}
}
